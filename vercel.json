{
  "buildCommand": "npm run build",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/about", "destination": "/about.html" },
    { "source": "/frameworks", "destination": "/frameworks.html" },
    { "source": "/manifesto", "destination": "/manifesto.html" },
    { "source": "/coaching", "destination": "/coaching.html" },
    { "source": "/privacy", "destination": "/privacy.html" },
    { "source": "/press", "destination": "/press.html" },
    { "source": "/blog/:path*", "destination": "https://app.joinsocialcode.com/blog/:path*" },
    { "source": "/blog", "destination": "https://app.joinsocialcode.com/blog" }
  ]
}
